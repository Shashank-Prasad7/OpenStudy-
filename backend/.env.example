APP_NAME=OpenStudy API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg:///
ALEMBIC_DATABASE_URL=postgresql+asyncpg:///
REDIS_URL=redis:///

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
COOKIE_SECURE=false
COOKIE_DOMAIN=

CORS_ORIGINS=http://localhost:5173,http:////

GROQ_API_KEY=
GROQ_MODEL=

AUTH_RATE_LIMIT=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
