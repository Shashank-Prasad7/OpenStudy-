APP_NAME=OpenStudy API
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api
DATABASE_URL=postgresql+asyncpg://openstudy:openstudy@localhost:5432/openstudy
ALEMBIC_DATABASE_URL=postgresql+asyncpg://openstudy:openstudy@localhost:5432/openstudy
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
COOKIE_SECURE=false
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://*.vercel.app
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AUTH_RATE_LIMIT=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
POMODORO_RETENTION_HOURS=24
